<%- include('partials/header') %>

<h1><%= title %></h1>

<ul>
  <% users.forEach(user => { %>
    <li>
      <a href="/user/<%= user.id %>"><%= user.name %></a>
      <span class="role"><%= user.role %></span>
    </li>
  <% }) %>
</ul>

<ul>
  <% for(let i=0;i<5;i++) { %>
    <% if(i%2===0) {%>
    <li>
      <a href="/user/<%= i %>">Data ke-<%= i %></a>
    </li>
    <% }else { %>
    <li>
      <a href="/user/<%= i %>">Bukan Data ke-<%= i %></a>
    </li>
  <% }} %>
</ul>

<%- include('partials/footer') %>
