<%- include('../partials/header') %>

<div class="page-header">
  <h1>📦 Daftar Produk</h1>
  <a href="/products/new" class="btn btn-primary">+ Tambah Produk</a>
</div>

<%# Flash message %>
<% if (message) { %>
  <div class="alert alert-success"><%= message %></div>
<% } %>

<%# Form pencarian %>
<form action="/products" method="GET" class="search-form">
  <input
    type="text"
    name="search"
    value="<%= search %>"
    placeholder="Cari nama produk..."
    class="input"
  />
  <button type="submit" class="btn btn-secondary">🔍 Cari</button>
  <% if (search) { %>
    <a href="/products" class="btn btn-outline">✕ Reset</a>
  <% } %>
</form>

<% if (search) { %>
  <p class="search-info">
    Menampilkan <strong><%= products.length %></strong> hasil untuk "<em><%= search %></em>"
  </p>
<% } %>

<%# Tabel produk %>
<% if (products.length === 0) { %>
  <div class="empty-state">
    <p>😕 Tidak ada produk ditemukan.</p>
    <a href="/products" class="btn btn-outline">Lihat Semua Produk</a>
  </div>
<% } else { %>
  <div class="table-wrapper">
    <table class="table">
      <thead>
        <tr>
          <th>#</th>
          <th>Nama Produk</th>
          <th>Kategori</th>
          <th>Harga</th>
          <th>Stok</th>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% products.forEach((product, i) => { %>
          <tr>
            <td><%= i + 1 %></td>
            <td><strong><%= product.name %></strong></td>
            <td><span class="badge"><%= product.category %></span></td>
            <td>Rp <%= product.price.toLocaleString('id-ID') %></td>
            <td>
              <span class="<%= product.stock < 5 ? 'text-danger' : 'text-success' %>">
                <%= product.stock %> unit
              </span>
            </td>
            <td class="actions">
              <a href="/products/<%= product.id %>" class="btn btn-sm btn-info">Detail</a>
              <a href="/products/<%= product.id %>/edit" class="btn btn-sm btn-warning">Edit</a>
              <form action="/products/<%= product.id %>?_method=DELETE" method="POST" class="inline-form"
                    onsubmit="return confirm('Hapus produk ini?')">
                <button type="submit" class="btn btn-sm btn-danger">Hapus</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <p class="table-footer">Total: <strong><%= products.length %></strong> produk</p>
<% } %>

<%- include('../partials/footer') %>
